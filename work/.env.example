# Supabase (required). Set in Vercel → Environment Variables for work.alessannailu.com.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Base URL path for the SPA. For https://work.alessannailu.com/ leave unset or use:
# VITE_BASE_PATH=/
# (Only set a value like /crm/ if the app is hosted under a path, not on this subdomain.)
