# Supabase (required). Vite exposes only vars prefixed with VITE_.
# Local: copy to .env and fill values. Production: Vercel → Settings → Environment Variables
# (set for Production and Preview — they are baked in at `npm run build`).

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: SPA base path (default / for work.alessannailu.com)
# VITE_BASE_PATH=/
