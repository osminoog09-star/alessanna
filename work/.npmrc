# HTTPS к registry.npmjs.org: использовать корневые CA из ОС (Windows/macOS/Linux).
# Снимает UNABLE_TO_VERIFY_LEAF_SIGNATURE за корпоративным прокси, если в систему добавлен корневой сертификат.
# Требуется Node.js 20.12+ (или новее 22.x). Иначе удалите следующую строку или обновите Node.
node-options=--use-system-ca
