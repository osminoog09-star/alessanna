# Copy to .env and set values. Never commit .env.

PORT=3000
JWT_SECRET=change-this-to-a-long-random-string-in-production

# QR session lifetime (ms), default 120000
QR_SESSION_MS=120000

# Optional: full public origin if QR links must not use request host (e.g. https://salon.ee)
# PUBLIC_BASE_URL=

# Next.js CRM dev server origin for CORS (e.g. http://localhost:3001). Set when running `npm run crm:dev`.
# CRM_DEV_ORIGIN=

# Emergency only: enable POST /api/auth/login with email+password
# ALLOW_PASSWORD_LOGIN=false

# Admin break-glass (email + phone must match for /api/auth/admin-direct and QR phone login)
# ADMIN_EMAIL=
# ADMIN_PHONE=

# Supabase — CRM (work/), public booking (public-site/), reminder job
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Vite CRM: copy work/.env.example → work/.env (VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY)
# Reminders (optional email via nodemailer: npm install nodemailer)
# REMINDER_SMTP_URL=smtps://user:pass@smtp.example.com:465
# REMINDER_EMAIL_FROM=noreply@example.com
# REMINDER_EMAIL_TO=owner@example.com
# CORS for Vite dev CRM: CRM_DEV_ORIGIN=http://localhost:5173

# Stripe Checkout (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Telegram bot (work login QR → t.me/Bot?start=TOKEN). Create bot via @BotFather.
# TELEGRAM_BOT_USERNAME=YourWorkBot   (without @)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# Same token can be used below for booking alerts if desired.

# Optional: Telegram (booking alerts) — see server/notifications.js
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: WhatsApp Cloud API — see server/notifications.js
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Optional: Google Calendar OAuth — see server/googleCalendar.js
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
